rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // True only for real (non-anonymous) signed-in users
    function isRealUser() {
      return isAuthenticated() && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Real user who owns the document
    function isRealOwner(userId) {
      return isRealUser() && request.auth.uid == userId;
    }
    
    // Users collection
    match /users/{userId} {
      // Allow any authenticated user to read user documents (needed for
      // display name lookups in playlist cards, profile views, etc.)
      allow read: if isAuthenticated();
      // Allow users to create/update their own user document
      allow write: if isOwner(userId);
      
      // Reviews subcollection
      match /reviews/{reviewId} {
        // Allow authenticated users to read all reviews (for community feed)
        allow read: if isAuthenticated();
        // Only real (non-anonymous) users can create or modify reviews.
        // Repost copies have the original author's userId, so we check
        // repostedByUserId == auth.uid instead for those documents.
        allow create: if isRealOwner(userId) && (
          request.resource.data.userId == userId ||
          (request.resource.data.isRepost == true &&
           request.resource.data.repostedByUserId == request.auth.uid)
        );
        allow update, delete: if isRealOwner(userId) && resource.data.userId == userId;
      }
      
      // Music preferences subcollection
      match /musicPreferences/{prefId} {
        allow read, write: if isOwner(userId);
      }
      
      // Review analysis cache subcollection
      match /reviewAnalysis/{cacheId} {
        allow read, write: if isOwner(userId);
      }
      
      // Friends subcollection
      match /friends/{friendId} {
        // Only the owner can read and write their own friends list
        allow read, write: if isOwner(userId);
      }
      
      // Notifications subcollection
      match /notifications/{notificationId} {
        // Only the owner can read notifications
        allow read: if isOwner(userId);
        // Any authenticated user can create a notification for another user,
        // but only for themselves as the actor.
        allow create: if isAuthenticated() &&
                         request.resource.data.actorId == request.auth.uid;
        // Only the owner can update/delete (e.g., mark read)
        allow update, delete: if isOwner(userId);
      }
      
      // Signals subcollection (AI-powered search: rec clicks, search queries, etc.)
      match /signals/{signalId} {
        allow read, write: if isOwner(userId);
      }
      
      // Recommendation outcomes subcollection (feedback loop for learning)
      match /recommendationOutcomes/{outcomeId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // Track genres collection (top-level, shared cache)
    match /trackGenres/{trackId} {
      // Allow authenticated users to read/write genre cache
      allow read, write: if isAuthenticated();
    }
    
    // Album art collection (top-level, shared cache)
    match /albumArt/{cacheId} {
      // Allow authenticated users to read/write album art cache
      allow read, write: if isAuthenticated();
    }
    
    // Wikipedia bios collection (top-level, shared cache)
    match /wikipediaBios/{cacheId} {
      // Allow authenticated users to read/write Wikipedia bio cache
      allow read, write: if isAuthenticated();
    }
    
    // User playlists collection (top-level)
    match /playlists/{playlistId} {
      // Allow any authenticated user to read playlists (for community/friends feeds)
      allow read: if isAuthenticated();
      // Allow users to create playlists (must set userId to their own)
      allow create: if isAuthenticated() &&
                       request.resource.data.userId == request.auth.uid;
      // Allow users to update/delete their own playlists
      allow update, delete: if isAuthenticated() &&
                               resource.data.userId == request.auth.uid;

      // Comments subcollection on a crate/playlist
      match /comments/{commentId} {
        // Any authenticated user can read all comments
        allow read: if isAuthenticated();
        // Any authenticated user can post a comment (must own the userId field)
        allow create: if isAuthenticated() &&
                         request.resource.data.userId == request.auth.uid &&
                         request.resource.data.text is string &&
                         request.resource.data.text.size() > 0 &&
                         request.resource.data.text.size() <= 1000;
        // Only the comment author can update their own comment
        allow update: if isAuthenticated() &&
                         resource.data.userId == request.auth.uid;
        // Comment author OR playlist owner can delete
        allow delete: if isAuthenticated() && (
                         resource.data.userId == request.auth.uid ||
                         get(/databases/$(database)/documents/playlists/$(playlistId)).data.userId == request.auth.uid
                       );
      }
    }
    
    // Collection group queries for reviews (allows reading reviews across all users)
    // This rule must come after the specific users/{userId}/reviews rule to avoid conflicts
    // The wildcard pattern matches any path ending in /reviews/{reviewId}
    match /{path=**}/reviews/{reviewId} {
      // Allow authenticated users to read any review (for community feed)
      allow read: if isAuthenticated();
      // Only real (non-anonymous) users can write reviews
      allow write: if isRealUser() &&
                      request.resource.data.userId == request.auth.uid;
    }
    
    // Playlist likes collection (top-level)
    // Structure: playlistLikes/{playlistId}/likes/{userId}
    match /playlistLikes/{playlistId} {
      allow read: if isAuthenticated();
      // No direct writes to the parent doc — only the subcollection matters
      allow write: if false;

      match /likes/{userId} {
        // Any authenticated user can check like status
        allow read: if isAuthenticated();
        // Users can only create/delete their own like document
        allow create: if isAuthenticated() && request.auth.uid == userId;
        allow delete: if isAuthenticated() && request.auth.uid == userId;
        allow update: if false;
      }
    }

    // Per-user liked playlist IDs (top-level)
    // Structure: userLikedPlaylists/{userId} — { playlistIds: [...] }
    match /userLikedPlaylists/{userId} {
      // Users can only read/write their own saved list
      allow read, write: if isOwner(userId);
    }

    // Reposts collection (top-level)
    // Structure: reposts/{sanitizedReviewId} (count doc) + /reposters/{userId}
    match /reposts/{reviewId} {
      allow read: if isAuthenticated();
      // Real users can write the count document (incremented on repost/unrepost)
      allow write: if isRealUser();

      match /reposters/{userId} {
        allow read: if isAuthenticated();
        allow create: if isRealUser() && request.auth.uid == userId;
        allow delete: if isRealUser() && request.auth.uid == userId;
        allow update: if false;
      }
    }

    // Review comments collection (top-level)
    // Structure: reviewComments/{sanitizedReviewId}/comments/{commentId}
    match /reviewComments/{reviewId} {
      allow read: if isAuthenticated();
      allow write: if false; // only subcollection matters

      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() &&
                         request.resource.data.userId == request.auth.uid &&
                         request.resource.data.text is string &&
                         request.resource.data.text.size() > 0 &&
                         request.resource.data.text.size() <= 1000;
        allow update: if isAuthenticated() &&
                         resource.data.userId == request.auth.uid;
        allow delete: if isAuthenticated() &&
                         resource.data.userId == request.auth.uid;

        // Per-user comment likes
        match /likes/{userId} {
          allow read: if isAuthenticated();
          allow create: if isAuthenticated() && request.auth.uid == userId;
          allow delete: if isAuthenticated() && request.auth.uid == userId;
          allow update: if false;
        }
      }
    }

    // Review likes collection (top-level)
    match /reviewLikes/{reviewId} {
      // Allow authenticated users to read like counts
      allow read: if isAuthenticated();
      // Allow create/update for count increments; block delete to protect count integrity.
      allow create, update: if isAuthenticated();
      allow delete: if false;
      
      // Likes subcollection (individual user likes)
      match /likes/{userId} {
        // Allow users to read all likes (to check if someone liked)
        allow read: if isAuthenticated();
        // Allow users to create/delete their own likes only
        allow create: if isAuthenticated() && request.auth.uid == userId;
        allow delete: if isAuthenticated() && request.auth.uid == userId;
        // No updates allowed (only create/delete)
        allow update: if false;
      }
    }
  }
}
